<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<VBox spacing="18" alignment="CENTER" prefWidth="560" prefHeight="560"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.AdminController">

    <Label text="PANEL DE ADMINISTRADOR"
           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 25;"/>

    <Button fx:id="btnUsuarios" text="Gestionar Usuarios Autorizados"
            onAction="#irGestionUsuarios" prefWidth="400" style="-fx-font-size: 15px;"/>

    <Button fx:id="btnTarifas" text="Gestionar Tarifas"
            onAction="#irGestionTarifas" prefWidth="400" style="-fx-font-size: 15px;"/>

    <Button fx:id="btnEspacios" text="Gestionar Espacios"
            onAction="#irGestionEspacios" prefWidth="400" style="-fx-font-size: 15px;"/>

    <Button fx:id="btnVehiculos" text="Gestionar Vehículos"
            onAction="#irGestionVehiculos" prefWidth="400" style="-fx-font-size: 15px;"/>

    <Button fx:id="btnReportes" text="Ver Reportes Generales"
            onAction="#irReportes" prefWidth="400" style="-fx-font-size: 15px;"/>

    <Button fx:id="btnCerrarSesion"
            text="Cerrar Sesión"
            onAction="#cerrarSesion"
            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold;"
            prefWidth="400"/>

</VBox>
