<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<VBox spacing="15" alignment="CENTER" prefWidth="500" prefHeight="500"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.AdminController">

    <Label text="PANEL DE ADMINISTRADOR"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 15;"/>

    <Button fx:id="btnUsuarios" text="Gestionar Usuarios" onAction="#irGestionUsuarios" prefWidth="300"/>
    <Button fx:id="btnVehiculos" text="Gestionar Vehículos" onAction="#irGestionVehiculos" prefWidth="300"/>
    <Button fx:id="btnEspacios" text="Gestionar Espacios" onAction="#irGestionEspacios" prefWidth="300"/>
    <Button fx:id="btnReportes" text="Ver Reportes" onAction="#irReportes" prefWidth="300"/>

    <Button fx:id="btnCerrarSesion"
            text="Cerrar Sesión"
            onAction="#cerrarSesion"
            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold;"/>

</VBox>