<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<VBox fx:id="root" spacing="18" alignment="CENTER" prefWidth="520" prefHeight="520"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.OperadorMenuController">

    <Label text="MENÚ OPERADOR - PARKUQ"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 15;"/>

    <Button text="Registrar Ingreso de Vehículo"
            onAction="#irRegistrarIngreso"
            prefWidth="380" style="-fx-font-size: 14px;"/>

    <Button text="Registrar Salida de Vehículo"
            onAction="#irRegistrarSalida"
            prefWidth="380" style="-fx-font-size: 14px;"/>

    <Button text="Ver Vehículos Dentro"
            onAction="#verVehiculosDentro"
            prefWidth="380" style="-fx-font-size: 14px;"/>

    <Button text="Ver Espacios Disponibles"
            onAction="#verEspaciosDisponibles"
            prefWidth="380" style="-fx-font-size: 14px;"/>

    <Button text="Ver Reportes"
            onAction="#verReportes"
            prefWidth="380" style="-fx-font-size: 14px;"/>

    <Button text="Cerrar Sesión"
            onAction="#cerrarSesion"
            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold;"
            prefWidth="380"/>

</VBox>