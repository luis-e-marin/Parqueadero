<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<VBox spacing="15" alignment="CENTER" prefWidth="400" prefHeight="300"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.LoginController">

    <Label text="INICIAR SESIÓN" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtUsuario" promptText="Usuario" prefWidth="250"/>
    <PasswordField fx:id="txtClave" promptText="Contraseña" prefWidth="250"/>

    <Button text="Ingresar" onAction="#login" prefWidth="150"/>

    <Label fx:id="lblMensaje" style="-fx-text-fill: red;"/>

</VBox>
