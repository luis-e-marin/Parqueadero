<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<VBox fx:id="root" spacing="15" alignment="CENTER" prefWidth="500" prefHeight="400"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.viewController.SalidaViewController">

    <Label text="REGISTRAR SALIDA" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtPlacaSalida" promptText="Placa del vehículo a retirar"/>

    <Button text="Registrar Salida" onAction="#registrarSalida" prefWidth="300"/>
    <Button text="Volver al Menú" onAction="#volverAlMenu" prefWidth="300"/>

    <TextArea fx:id="areaResultado" prefHeight="150" editable="false"/>
</VBox>
