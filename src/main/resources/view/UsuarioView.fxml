<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<VBox spacing="12" alignment="CENTER" prefWidth="550" prefHeight="550"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.UsuarioController">

    <Label text="GESTIÓN DE USUARIOS" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtNombre" promptText="Nombre completo" prefWidth="200"/>
        <TextField fx:id="txtId" promptText="Identificación" prefWidth="150"/>
    </HBox>

    <ComboBox fx:id="comboTipo" promptText="Tipo de Usuario" prefWidth="250"/>

    <HBox spacing="10">
        <Button text="Crear Usuario" onAction="#crearUsuario" prefWidth="140"/>
        <Button text="Buscar Usuario" onAction="#buscarUsuario" prefWidth="140"/>
        <Button text="Editar Usuario" onAction="#editarUsuario" prefWidth="140"/>
    </HBox>

    <Button text="Ver Vehículos del Usuario" onAction="#verVehiculos" prefWidth="300"/>

    <Button text="← Volver al Menú Admin"
            onAction="#volverAlAdmin"
            style="-fx-background-color: #d32f2f; -fx-text-fill: white;"/>

    <TextArea fx:id="areaResultado" prefHeight="200" editable="false"/>

</VBox>