<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<VBox spacing="10" alignment="CENTER" prefWidth="800" prefHeight="600"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.EspaciosController">

    <Label text="GESTIÓN DE ESPACIOS" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="tablaEspacios" prefHeight="400">
        <columns>
            <TableColumn text="Código" fx:id="colCodigo" prefWidth="100"/>
            <TableColumn text="Tipo" fx:id="colTipo" prefWidth="150"/>
            <TableColumn text="Estado" fx:id="colEstado" prefWidth="150"/>
            <TableColumn text="Vehículo Actual" fx:id="colVehiculo" prefWidth="200"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtCodigo" promptText="Código del espacio" prefWidth="150"/>
        <Button text="Deshabilitar" onAction="#deshabilitarEspacio"/>
        <Button text="Habilitar" onAction="#habilitarEspacio"/>
        <Button text="← Volver al Menú Admin"
                onAction="#volverAlAdmin"
                style="-fx-background-color: #d32f2f; -fx-text-fill: white;"/>
    </HBox>

</VBox>