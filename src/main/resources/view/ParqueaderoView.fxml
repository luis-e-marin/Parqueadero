<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<VBox spacing="12" alignment="CENTER" prefWidth="600" prefHeight="650"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.controller.ParqueaderoController">

    <Label text="CONTROL DE PARQUEADERO - OPERADOR"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Ingreso de vehículo -->
    <Label text="Registrar Ingreso de Vehículo" style="-fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtPlaca" promptText="Placa" prefWidth="120"/>
        <ComboBox fx:id="comboTipo" promptText="Tipo Vehículo" prefWidth="150"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtNombreConductor" promptText="Nombre del Conductor" prefWidth="200"/>
        <TextField fx:id="txtIdConductor" promptText="Identificación" prefWidth="150"/>
    </HBox>

    <Button text="Registrar Ingreso" onAction="#registrarIngreso" prefWidth="250" style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>

    <!-- Salida de vehículo -->
    <Label text="Registrar Salida de Vehículo" style="-fx-font-weight: bold; margin-top: 20;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtPlacaSalida" promptText="Placa del vehículo a salir" prefWidth="200"/>
        <Button text="Registrar Salida" onAction="#registrarSalida" prefWidth="180"/>
    </HBox>

    <Button text="← Volver al Menú Admin" onAction="#volverAlAdmin"
            style="-fx-background-color: #d32f2f; -fx-text-fill: white;"/>

    <TextArea fx:id="areaResultado" prefHeight="200" editable="false" style="-fx-font-family: monospace;"/>

</VBox>
