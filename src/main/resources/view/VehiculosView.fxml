<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<VBox spacing="15" alignment="CENTER" prefWidth="560" prefHeight="520"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniquindio.edu.co.viewController.VehiculosAdminViewController">

    <Label text="GESTIÓN DE VEHÍCULOS"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 15;"/>

    <TextField fx:id="txtPlacaBuscar" promptText="Buscar por placa"/>
    <Button text="Buscar Vehículo" onAction="#buscarVehiculo" prefWidth="300"/>

    <TextArea fx:id="areaResultado" prefHeight="250" editable="false"/>

    <Button text="Ver Todos los Vehículos" onAction="#verTodosVehiculos" prefWidth="300"/>
    <Button text="Eliminar Vehículo" onAction="#eliminarVehiculo" prefWidth="300"/>

    <Button text="Volver al Panel Admin" onAction="#volverAlAdmin" prefWidth="300"/>

</VBox>
